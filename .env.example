# ─────────────────────────────────────────────────────────────────────────────
# VibeSiteScan environment. Copy to `.env.local` and fill in real values.
# The app RUNS with none of these (in-memory demo mode). Fill them to unlock
# durable certificates (Supabase) and paid plans (Razorpay).
# ─────────────────────────────────────────────────────────────────────────────

# App URL — used in certificate links and the embeddable badge <img> src.
# Set to your real domain in production (e.g. https://vibesitescan.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (durable scans, certificates, accounts, credits) ────────────────
# From: Supabase dashboard → Project Settings → API.
# Without these, certificates live only in server memory (reset on restart).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # SECRET — server only

# ── Razorpay (subscriptions + credit top-ups) ────────────────────────────────
# From: Razorpay Dashboard → Settings → API Keys (use Test keys first).
# Without these, billing routes return "not configured" and the app stays free-tier.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret              # SECRET — server only
RAZORPAY_WEBHOOK_SECRET=your-webhook-signing-secret       # SECRET — set in webhook config

# Razorpay subscription Plan IDs (create under Subscriptions → Plans).
RAZORPAY_PLAN_STARTER=plan_xxxxxxxxxxxxx   # Rs 799/mo, 250 credits
RAZORPAY_PLAN_AGENCY=plan_xxxxxxxxxxxxx    # Rs 1999/mo, 1000 credits

# Optional: expose the public key id to the client checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
